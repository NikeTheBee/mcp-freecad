__pycache__/
*.pyc
*.FCBak
.vscode/

# Third-party MCP base server — cloned locally, not vendored (see install/WINDOWS-SETUP.md)
/server/freecad-mcp/

# Third-party FreeCAD workbenches (grafts) — cloned locally, not vendored
/addons/

# Local, machine-specific Claude Code settings
.claude/settings.local.json

# Secrets — never commit (cyber / NF5 / §13). Defense in depth.
.env
.env.*
*.pem
*.key
*.p12
*.pfx
id_rsa*
credentials.json
secrets.*
*.secret

# Per-project runtime artifacts from the home-grown layers (keep the dirs, not the data)
/project_state/*.json
/checkpoints/*.FCStd
/checkpoints/*.FCStd[0-9]*

# Runtime output of examples/resume_between_sessions.py
/examples/demo_state/
